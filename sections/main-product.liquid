<div class="pt-32 pb-24 px-6 md:px-20 min-h-screen bg-background">
  <div class="max-w-7xl mx-auto">
    <a href="/collections/all" class="inline-flex items-center gap-4 text-primary/40 hover:text-primary transition-colors py-4 mb-12 group">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 group-hover:-translate-x-2 transition-transform"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
      <span class="text-[10px] font-black uppercase tracking-widest">Regresar a la Colección</span>
    </a>

    <div class="grid lg:grid-cols-12 gap-12 lg:gap-20 items-start">
      <!-- Left Column: Image Gallery -->
      <div class="lg:col-span-7 lg:sticky lg:top-32">
        <div class="relative aspect-[4/5] rounded-[48px] overflow-hidden shadow-2xl bg-surface-container-low p-1 border border-outline-variant/20">
          <img src="{{ product.featured_image | img_url: '1000x' }}" class="w-full h-full object-cover rounded-[44px]" alt="{{ product.title | escape }}" />
          {% if product.type != blank %}
            <div class="absolute top-8 right-8 bg-[#1a1c1a] text-white px-5 py-2 rounded-full text-[9px] font-black uppercase tracking-[0.2em] shadow-xl backdrop-blur-md bg-opacity-90">
              {{ product.type }}
            </div>
          {% endif %}
        </div>
      </div>

      <!-- Right Column: Product Details -->
      <div class="lg:col-span-5 space-y-12">
        <div class="space-y-6">
          <div class="space-y-3">
            <span class="text-[10px] font-black tracking-[0.4em] uppercase text-[#d4af37]">Ritual Cosmético ✧ Selección</span>
            <h1 class="font-serif text-5xl md:text-7xl text-primary leading-tight tracking-tight">{{ product.title }}</h1>
          </div>
          
          <div class="flex items-baseline gap-6 py-6 border-b border-outline-variant/20">
            <span class="text-5xl font-serif text-primary italic" id="product-price">
              {{ product.price | money }}
            </span>
            <span class="text-[10px] font-black uppercase tracking-widest text-primary/30">Precio Final</span>
          </div>

          <div class="text-lg text-on-surface-variant/80 font-light leading-relaxed pt-2">
            {{ product.description }}
          </div>
        </div>

        <div class="space-y-8">
          {% form 'product', product, id: 'add-to-cart-form' %}
            
            {% unless product.has_only_default_variant %}
              <div class="p-8 bg-surface-container-lowest rounded-[32px] border border-outline-variant/30 shadow-sm">
                <h4 class="text-[9px] font-black tracking-[0.3em] uppercase text-primary/40 mb-6">Selecciona tu opción</h4>
                <select name="id" id="variant-select" class="w-full bg-transparent border-0 border-b border-outline-variant focus:border-accent focus:ring-0 py-4 transition-all text-[14px]">
                  {% for variant in product.variants %}
                    <option value="{{ variant.id }}" data-price="{{ variant.price | money }}" {% if variant == product.selected_or_first_available_variant %}selected="selected"{% endif %} {% unless variant.available %}disabled="disabled"{% endunless %}>
                      {{ variant.title }} - {{ variant.price | money }}
                    </option>
                  {% endfor %}
                </select>
              </div>
            {% else %}
              <input type="hidden" name="id" value="{{ product.variants.first.id }}">
            {% endunless %}

            <div class="flex flex-col sm:flex-row gap-4 pt-6">
              <button type="submit" name="add" class="flex-1 py-6 bg-[#1a1c1a] text-white rounded-2xl text-[11px] font-black tracking-[0.3em] uppercase hover:bg-primary shadow-xl active:scale-[0.98] transition-all cursor-pointer flex items-center justify-center gap-3" {% unless product.available %}disabled{% endunless %}>
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                {% if product.available %}
                  Añadir al Carrito
                {% else %}
                  Agotado
                {% endif %}
              </button>
            </div>
          {% endform %}
        </div>

      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const variantSelect = document.getElementById('variant-select');
    const priceDisplay = document.getElementById('product-price');
    
    if (variantSelect && priceDisplay) {
      variantSelect.addEventListener('change', function() {
        const selectedOption = this.options[this.selectedIndex];
        priceDisplay.textContent = selectedOption.getAttribute('data-price');
      });
    }

    // Intercept form submit using AJAX
    const cartForm = document.getElementById('add-to-cart-form');
    if (cartForm) {
      cartForm.addEventListener('submit', function(e) {
        e.preventDefault();
        
        const submitBtn = cartForm.querySelector('button[type="submit"]');
        if (!submitBtn) return;
        
        const originalText = submitBtn.innerHTML;
        
        // Premium loading state
        submitBtn.disabled = true;
        submitBtn.style.opacity = '0.75';
        submitBtn.innerHTML = `
          <svg class="animate-spin" style="width:16px; height:16px; animation: luxurySpin 0.8s linear infinite;" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle style="opacity: 0.25;" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path style="opacity: 0.75;" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
          <span>Agregando...</span>
        `;
        
        const formData = new FormData(cartForm);
        
        fetch('/cart/add.js', {
          method: 'POST',
          body: formData
        })
        .then(res => res.json())
        .then(() => {
          submitBtn.disabled = false;
          submitBtn.style.opacity = '1';
          submitBtn.innerHTML = originalText;
          
          // Open global custom AJAX Cart Drawer!
          if (window.openLuxuryCart) {
            window.openLuxuryCart();
          } else {
            window.location.href = '/cart';
          }
        })
        .catch(err => {
          console.error(err);
          submitBtn.disabled = false;
          submitBtn.style.opacity = '1';
          submitBtn.innerHTML = originalText;
          window.location.href = '/cart';
        });
      });
    }
  });
</script>

<style>
  @keyframes luxurySpin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
</style>

{% schema %}
{
  "name": "Product Details",
  "settings": []
}
{% endschema %}
