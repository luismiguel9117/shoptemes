<footer class="bg-surface-container border-t border-outline-variant/30 mt-32">
  <div class="max-w-7xl mx-auto px-6 md:px-20 py-24 grid grid-cols-1 md:grid-cols-4 gap-12">
    <div class="space-y-8">
      <a href="/" class="cursor-pointer block">
        <div class="flex items-center gap-3 group">
          <div class="relative w-24 h-24 rounded-full border border-accent/20 overflow-hidden flex items-center justify-center flex-shrink-0 shadow-sm transition-all duration-500 group-hover:border-accent/40">
            <img src="{{ 'logo.png' | asset_url }}" alt="Ritual Cosmetico Logo" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700 relative z-10" />
          </div>
          <div class="flex flex-col -space-y-1.5">
            <span class="font-serif text-4xl font-bold tracking-[0.1em] uppercase text-on-surface leading-tight">Ritual</span>
            <span class="font-serif text-lg font-medium tracking-[0.1em] uppercase text-accent leading-tight">Cosmético</span>
          </div>
        </div>
      </a>
      <p class="text-[16px] text-on-surface-variant max-w-xs font-light">
        Elevando el cuidado personal a través del diseño y la sofisticación cosmética en Lima, Perú.
      </p>
      <div class="flex gap-4">
        <!-- Icons -->
        <a href="{{ settings.social_instagram_link }}" target="_blank" class="text-primary hover:opacity-50 transition-opacity">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
        </a>
      </div>
    </div>
    
    <div>
      <h4 class="text-[12px] font-bold text-primary mb-8 uppercase tracking-[0.2em]">Tienda</h4>
      <ul class="space-y-4">
        {% for link in linklists.footer.links %}
          <li><a href="{{ link.url }}" class="text-on-surface-variant hover:text-primary transition-colors text-[14px] font-medium">{{ link.title }}</a></li>
        {% endfor %}
      </ul>
    </div>
    
    <div>
      <h4 class="text-[12px] font-bold text-primary mb-8 uppercase tracking-[0.2em]">Asistencia</h4>
      <ul class="space-y-4">
        <li><a href="/pages/envios" class="text-on-surface-variant hover:text-primary transition-colors text-[14px] font-medium">Envíos & Devoluciones</a></li>
        <li><a href="/pages/faq" class="text-on-surface-variant hover:text-primary transition-colors text-[14px] font-medium">Preguntas Frecuentes</a></li>
        <li><a href="/pages/contacto" class="text-on-surface-variant hover:text-primary transition-colors text-[14px] font-medium">Contacto</a></li>
      </ul>
    </div>
    
    <div>
      <h4 class="text-[12px] font-bold text-primary mb-8 uppercase tracking-[0.2em]">Legal</h4>
      <ul class="space-y-4">
        <li><a href="/policies/privacy-policy" class="text-on-surface-variant hover:text-primary transition-colors text-[14px] font-medium">Política de Privacidad</a></li>
        <li><a href="/policies/terms-of-service" class="text-on-surface-variant hover:text-primary transition-colors text-[14px] font-medium">Términos de Servicio</a></li>
      </ul>
    </div>
  </div>
  <div class="max-w-7xl mx-auto px-6 md:px-20 py-8 border-t border-outline-variant/20 flex flex-col md:flex-row justify-between items-center gap-4">
    <p class="text-on-surface-variant text-[14px]">© {{ 'now' | date: "%Y" }} {{ shop.name }}. Diseñado en Lima.</p>
    <div class="flex gap-8 items-center text-[10px] font-bold text-outline-variant tracking-widest uppercase">
      <span>PERÚ</span>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": []
}
{% endschema %}
