{%- comment -%}
  Ritual Cosmético / ShopTHEMES - Footer Premium Luxury (OS 2.0)
  Pie de página de alta gama con soporte para selector de logotipo, boletín minimalista y animaciones de enlaces fluidas.
{%- endcomment -%}

<style>
  .luxury-footer {
    --bg-color: {{ section.settings.bg_color }};
    --text-color: {{ section.settings.text_color }};
    --heading-font: 'Cormorant Garamond', serif;
    --sans-font: 'Montserrat', sans-serif;
    
    background-color: var(--bg-color);
    color: var(--text-color);
    font-family: var(--sans-font);
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    padding: 6rem 4rem 3rem 4rem;
    box-sizing: border-box;
  }
  @media (max-width: 768px) {
    .luxury-footer {
      padding: 4rem 2rem 2rem 2rem;
    }
  }

  .luxury-footer__container {
    max-width: 1600px;
    margin: 0 auto;
    width: 100%;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 2fr;
    gap: 4rem;
    box-sizing: border-box;
  }
  @media (max-width: 1024px) {
    .luxury-footer__container {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 576px) {
    .luxury-footer__container {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }

  /* Brand Column */
  .luxury-footer__brand {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    align-items: flex-start;
  }
  .luxury-footer__logo {
    text-decoration: none;
    display: inline-block;
  }
  .luxury-footer__logo-text {
    font-family: var(--heading-font);
    font-size: 28px;
    font-weight: 300;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--text-color);
    margin-right: -0.3em;
  }
  .luxury-footer__logo-img {
    display: block;
    height: auto;
    object-fit: contain;
  }
  .luxury-footer__desc {
    font-size: 13px;
    font-weight: 300;
    line-height: 1.8;
    color: var(--text-color);
    opacity: 0.7;
    max-width: 320px;
    margin: 0;
  }
  .luxury-footer__socials {
    display: flex;
    gap: 1.25rem;
    align-items: center;
    margin-top: 0.5rem;
  }
  .luxury-footer__social-link {
    color: var(--text-color);
    opacity: 0.6;
    transition: opacity 0.3s ease, transform 0.3s cubic-bezier(0.25, 1, 0.5, 1);
  }
  .luxury-footer__social-link:hover {
    opacity: 1;
    transform: translateY(-2px);
  }

  /* Link Columns */
  .luxury-footer__col {
    display: flex;
    flex-direction: column;
  }
  .luxury-footer__col-title {
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    color: var(--text-color);
    opacity: 0.4;
    margin: 0 0 2rem 0;
  }
  @media (max-width: 576px) {
    .luxury-footer__col-title {
      margin-bottom: 1.25rem;
    }
  }
  .luxury-footer__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .luxury-footer__link {
    color: var(--text-color);
    text-decoration: none;
    font-size: 12px;
    font-weight: 300;
    letter-spacing: 0.1em;
    opacity: 0.7;
    transition: opacity 0.4s cubic-bezier(0.25, 1, 0.5, 1), transform 0.4s cubic-bezier(0.25, 1, 0.5, 1);
    display: inline-block;
  }
  .luxury-footer__link:hover {
    opacity: 1;
    transform: translateX(4px);
  }

  /* Newsletter Column */
  .luxury-footer__newsletter {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .luxury-footer__news-desc {
    font-size: 13px;
    font-weight: 300;
    line-height: 1.8;
    color: var(--text-color);
    opacity: 0.7;
    margin: 0;
    max-width: 400px;
  }
  .luxury-footer__form {
    position: relative;
    width: 100%;
    margin-top: 0.5rem;
  }
  .luxury-footer__input {
    width: 100%;
    background: transparent;
    border: none;
    border-bottom: 1px solid rgba(255, 255, 255, 0.15);
    padding: 0.75rem 3rem 0.75rem 0;
    color: var(--text-color);
    font-family: var(--sans-font);
    font-size: 13px;
    font-weight: 300;
    box-sizing: border-box;
    transition: border-bottom-color 0.4s ease;
  }
  .luxury-footer__input::placeholder {
    color: var(--text-color);
    opacity: 0.35;
  }
  .luxury-footer__input:focus {
    outline: none;
    border-bottom-color: var(--text-color);
  }
  .luxury-footer__form-btn {
    position: absolute;
    right: 0;
    bottom: 0.75rem;
    background: none;
    border: none;
    color: var(--text-color);
    cursor: pointer;
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    padding: 0;
    opacity: 0.8;
    transition: opacity 0.3s ease, right 0.3s cubic-bezier(0.25, 1, 0.5, 1);
  }
  .luxury-footer__form-btn:hover {
    opacity: 1;
    right: -4px;
  }

  /* Bottom Bar */
  .luxury-footer__bottom {
    max-width: 1600px;
    margin: 5rem auto 0 auto;
    width: 100%;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    display: flex;
    justify-content: space-between;
    align-items: center;
    box-sizing: border-box;
  }
  @media (max-width: 768px) {
    .luxury-footer__bottom {
      flex-direction: column;
      gap: 1.5rem;
      text-align: center;
      margin-top: 3.5rem;
    }
  }
  .luxury-footer__copyright {
    font-size: 11px;
    font-weight: 300;
    letter-spacing: 0.05em;
    opacity: 0.5;
    margin: 0;
  }
  .luxury-footer__location {
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.25em;
    opacity: 0.5;
    text-transform: uppercase;
  }
</style>

<footer class="luxury-footer">
  <div class="luxury-footer__container">
    <!-- Brand / Narrative Column -->
    <div class="luxury-footer__brand">
      <a href="{{ routes.root_url }}" class="luxury-footer__logo">
        {%- if section.settings.logo_type == 'image' and section.settings.logo_image != blank -%}
          <img
            src="{{ section.settings.logo_image | image_url: width: 300 }}"
            alt="{{ section.settings.brand_name | default: shop.name }}"
            style="max-width: {{ section.settings.logo_width }}px; height: auto;"
            class="luxury-footer__logo-img"
            width="{{ section.settings.logo_width }}"
            height="auto"
          >
        {%- else -%}
          <span class="luxury-footer__logo-text">{{ section.settings.brand_name }}</span>
        {%- endif -%}
      </a>
      
      <p class="luxury-footer__desc">
        {{ section.settings.brand_desc }}
      </p>
      
      <div class="luxury-footer__socials">
        {%- if settings.social_instagram_link != blank -%}
          <a href="{{ settings.social_instagram_link }}" target="_blank" class="luxury-footer__social-link" aria-label="Instagram">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
          </a>
        {%- endif -%}
        {%- if settings.social_facebook_link != blank -%}
          <a href="{{ settings.social_facebook_link }}" target="_blank" class="luxury-footer__social-link" aria-label="Facebook">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
        {%- endif -%}
        {%- if settings.social_pinterest_link != blank -%}
          <a href="{{ settings.social_pinterest_link }}" target="_blank" class="luxury-footer__social-link" aria-label="Pinterest">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 12a4 4 0 0 1 8 0v2a2 2 0 0 1-4 0v-2g"/></svg>
          </a>
        {%- endif -%}
      </div>
    </div>

    <!-- Boutique Links (Shopify Nav list or standard fallbacks) -->
    <div class="luxury-footer__col">
      <h3 class="luxury-footer__col-title">Boutique</h3>
      <ul class="luxury-footer__list">
        {%- if section.settings.menu_boutique != blank -%}
          {%- for link in linklists[section.settings.menu_boutique].links -%}
            <li><a href="{{ link.url }}" class="luxury-footer__link">{{ link.title }}</a></li>
          {%- endfor -%}
        {%- else -%}
          <li><a href="/collections/all" class="luxury-footer__link">Shop All Jewelry</a></li>
          <li><a href="/collections/rings" class="luxury-footer__link">Fine Rings</a></li>
          <li><a href="/collections/necklaces" class="luxury-footer__link">Gold Necklaces</a></li>
          <li><a href="/blogs/journal" class="luxury-footer__link">Editorial Journal</a></li>
        {%- endif -%}
      </ul>
    </div>

    <!-- Assistance Links -->
    <div class="luxury-footer__col">
      <h3 class="luxury-footer__col-title">Assistance</h3>
      <ul class="luxury-footer__list">
        {%- if section.settings.menu_assistance != blank -%}
          {%- for link in linklists[section.settings.menu_assistance].links -%}
            <li><a href="{{ link.url }}" class="luxury-footer__link">{{ link.title }}</a></li>
          {%- endfor -%}
        {%- else -%}
          <li><a href="/pages/envios" class="luxury-footer__link">Shipping & Returns</a></li>
          <li><a href="/pages/faq" class="luxury-footer__link">Sizing Guide & FAQs</a></li>
          <li><a href="/pages/private-styling" class="luxury-footer__link">Private Appointment</a></li>
          <li><a href="/pages/contacto" class="luxury-footer__link">Contact Boutique</a></li>
        {%- endif -%}
      </ul>
    </div>

    <!-- Newsletter "The Journal" -->
    <div class="luxury-footer__newsletter">
      <h3 class="luxury-footer__col-title">The Journal</h3>
      <p class="luxury-footer__news-desc">
        {{ section.settings.newsletter_text }}
      </p>
      
      {%- form 'customer', class: 'luxury-footer__form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <input
          type="email"
          name="contact[email]"
          id="NewsletterEmail-{{ section.id }}"
          class="luxury-footer__input"
          value="{{ form.email }}"
          placeholder="ENTER YOUR EMAIL"
          autocorrect="off"
          autocapitalize="off"
          required
        >
        <button type="submit" class="luxury-footer__form-btn" name="commit">
          Join →
        </button>
        {%- if form.posted_successfully? -%}
          <p style="font-size: 11px; color: #d4af37; margin: 8px 0 0 0; font-weight: 300;">Thank you for subscribing.</p>
        {%- endif -%}
      {%- endform -%}
    </div>
  </div>

  <!-- Bottom Copyright & Details -->
  <div class="luxury-footer__bottom">
    <p class="luxury-footer__copyright">
      © {{ 'now' | date: "%Y" }} {{ section.settings.brand_name }}. Handcrafted in Gold. All rights reserved.
    </p>
    <div class="luxury-footer__location">
      {{ section.settings.bottom_location | default: 'LIMA, PERÚ' }}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer Premium Luxury",
  "settings": [
    {
      "type": "header",
      "content": "Logotipo de la Marca"
    },
    {
      "type": "select",
      "id": "logo_type",
      "label": "Tipo de Logotipo",
      "options": [
        {
          "value": "text",
          "label": "Logotipo de Texto"
        },
        {
          "value": "image",
          "label": "Isotipo o Logotipo en Imagen"
        }
      ],
      "default": "text"
    },
    {
      "type": "text",
      "id": "brand_name",
      "label": "Nombre de la Marca (Texto)",
      "default": "LUMINA"
    },
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Imagen del Logotipo (Isotipo)"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 30,
      "max": 180,
      "step": 5,
      "unit": "px",
      "label": "Ancho del Logotipo (Imagen)",
      "default": 90
    },
    {
      "type": "textarea",
      "id": "brand_desc",
      "label": "Descripción de la Marca",
      "default": "Timeless elegance handcrafted in 18k gold and fine natural diamonds. Designed in Lima to be cherished forever."
    },
    {
      "type": "header",
      "content": "Ajustes de Enlaces"
    },
    {
      "type": "link_list",
      "id": "menu_boutique",
      "label": "Menú - Boutique (Columna 1)"
    },
    {
      "type": "link_list",
      "id": "menu_assistance",
      "label": "Menú - Asistencia (Columna 2)"
    },
    {
      "type": "header",
      "content": "Boletín Informativo"
    },
    {
      "type": "textarea",
      "id": "newsletter_text",
      "label": "Texto del Boletín",
      "default": "Subscribe to receive updates on limited drop collections and invitations to private styling previews."
    },
    {
      "type": "header",
      "content": "Detalles del Pie"
    },
    {
      "type": "text",
      "id": "bottom_location",
      "label": "Ubicación",
      "default": "LIMA, PERÚ"
    },
    {
      "type": "header",
      "content": "Estilos y Colores"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Color de Fondo",
      "default": "#0a0a0a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Color de Texto",
      "default": "#ffffff"
    }
  ]
}
{% endschema %}
