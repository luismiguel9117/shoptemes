<section class="relative min-h-screen lg:min-h-[98vh] flex flex-col justify-center px-6 md:px-20 bg-gradient-to-br from-[#faf9f6] via-[#fdf7f2] to-[#f9ede4] overflow-hidden pt-36 md:pt-24 pb-12">
  <div class="absolute inset-x-0 top-[45%] -translate-y-1/2 flex items-center justify-center pointer-events-none overflow-hidden select-none">
    <span class="font-script text-[180px] md:text-[450px] text-[#e8dcd0]/30 rotate-[-5deg]">Nature</span>
  </div>
  
  <div class="relative z-10 w-full max-w-7xl mx-auto flex-1 flex flex-col justify-center">
    <div class="grid md:grid-cols-12 gap-8 lg:gap-16 items-center">
      <div class="md:col-span-12 lg:col-span-12 xl:col-span-5 space-y-16 relative z-30 fade-in-up">
        <div class="space-y-8">
          <h1 class="font-black text-[52px] sm:text-[68px] md:text-[88px] text-on-background leading-[0.9] tracking-tighter uppercase">
            Estética <br />
            <div class="flex flex-wrap items-center gap-4 py-2">
               <div class="h-10 w-24 md:h-14 md:w-32 bg-accent rounded-full overflow-hidden relative shadow-xl">
                <img src="https://images.unsplash.com/photo-1614850523296-d8c1af93d400?q=80&w=500&auto=format&fit=crop" class="w-full h-full object-cover mix-blend-overlay opacity-90 scale-125" alt="swirl" />
                <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/40 to-transparent animate-pulse"></div>
              </div>
              <span>&</span>
            </div>
            Selección <br /> Global
          </h1>
          <p class="text-[18px] text-on-surface-variant leading-relaxed max-w-[500px] font-light">
            Curamos cosméticos únicos alrededor del mundo para elevar tu ritual diario a una experiencia de diseño y sofisticación internacional.
          </p>
        </div>
        
        <div class="space-y-12">
          <a href="/collections/all" class="inline-block bg-[#1a1c1a] text-white px-14 py-5 rounded-full text-[14px] font-black tracking-[0.25em] hover:bg-primary transition-all duration-300 active:scale-95 shadow-xl shadow-black/20 cursor-pointer uppercase text-center">
            Ver productos
          </a>
        </div>
      </div>

      <div class="hidden md:flex md:col-span-12 xl:col-span-7 relative justify-center items-center h-[500px] md:h-[600px] lg:h-[750px] w-full mt-12 xl:mt-0 px-4 fade-in-right">
        <!-- Visual Composition Container -->
        <div class="relative w-full max-w-[550px] lg:max-w-[650px] h-full flex items-center justify-center">
          
          <!-- Shape 1: Product in Orange Oval (Back-Left) -->
          <div class="absolute left-[-5%] sm:left-[5%] xl:-left-8 top-[5%] sm:top-[2%] w-[65%] sm:w-[50%] lg:w-[55%] h-[60%] sm:h-[70%] md:h-[75%] rounded-[180px] bg-accent p-1.5 flex items-center justify-center shadow-2xl z-10">
            <div class="w-full h-full rounded-[180px] overflow-hidden bg-white/10 backdrop-blur-3xl relative">
              <img src="https://lh3.googleusercontent.com/aida/ADBb0uivlBTqQeWlmY4Bsq27R8eHPWBhnRuvegCEmnV3aNmPMxvZ4PAYjWbDDwE_XXxKEnfBBrlwvsHAzi6JZTttzcC68ND6_UMPSUW7ZkpOi3yJYagdnbDGWri_2X6Rkjga604kZYwgSZ1FZWpJWFs1pBGUSwCKhLVW0lXbw6tcKXltRwX9ddRFvZnOm-GAzdozT5CGyUnEBB1E1f9FrOfK6ACxHhHwxIAssjOh7yNHdfCx96OkXW3vFf45ols" alt="Producto" class="w-full h-full object-cover scale-110" />
              <div class="absolute inset-0 bg-gradient-to-t from-accent/40 to-transparent mix-blend-overlay"></div>
            </div>
          </div>

          <!-- Shape 2: Beauty Portrait (Front-Right) -->
          <div class="absolute right-[-5%] sm:right-[5%] xl:-right-12 top-[35%] sm:top-[15%] w-[70%] sm:w-[55%] lg:w-[60%] h-[70%] sm:h-[75%] md:h-[80%] rounded-[200px] overflow-hidden border-[12px] md:border-[16px] border-white/60 shadow-2xl z-20 bg-surface">
            <img src="https://images.unsplash.com/photo-1594744803329-e58b31de8bf5?q=80&w=1000&auto=format&fit=crop" alt="Retrato Belleza" class="w-full h-full object-cover" />
            <div class="absolute inset-0 shadow-[inset_0_0_80px_rgba(0,0,0,0.05)]"></div>
          </div>

          <!-- Background Accents (Blurred light) -->
          <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full h-full bg-accent/5 rounded-full blur-[120px] -z-10"></div>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero Section",
  "settings": [],
  "presets": [
    {
      "name": "Hero Default"
    }
  ]
}
{% endschema %}
