{%- comment -%}
  Ritual Cosmético / ShopTHEMES - Global Header Premium Luxury (OS 2.0 with Text/Image Logo Options)
  Sección independiente para la barra de navegación transparente superior con pestañas editables y selector de logotipo (Texto / Imagen).
{%- endcomment -%}

<style>
  .luxury-header {
    --text-color: {{ section.settings.text_color }};
    --heading-font: 'Cormorant Garamond', serif;
    --sans-font: 'Montserrat', sans-serif;
    --header-bg: transparent;
    --header-padding: 2.5rem 4rem;

    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 100;
    padding: var(--header-padding);
    background: var(--header-bg);
    box-sizing: border-box;
    transition: background-color 0.5s cubic-bezier(0.25, 1, 0.5, 1), padding 0.5s cubic-bezier(0.25, 1, 0.5, 1), border-color 0.5s cubic-bezier(0.25, 1, 0.5, 1);
    border-bottom: 1px solid transparent;
    font-family: var(--sans-font);
  }

  /* Scrolled Page or Non-Home Page States */
  .luxury-header.scrolled,
  .luxury-header.non-index {
    --header-bg: rgba(13, 13, 13, 0.85);
    --header-padding: 1.5rem 4rem;
    border-bottom-color: rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
  }

  @media (max-width: 768px) {
    .luxury-header {
      --header-padding: 1.5rem 2rem;
    }
    .luxury-header.scrolled,
    .luxury-header.non-index {
      --header-padding: 1rem 2rem;
    }
  }

  .luxury-header__container {
    max-width: 1600px;
    margin: 0 auto;
    width: 100%;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    align-items: center;
    box-sizing: border-box;
  }

  @media (max-width: 768px) {
    .luxury-header__container {
      display: flex;
      justify-content: space-between;
    }
    .luxury-header__nav-desktop {
      display: none !important;
    }
  }

  /* Navigation Links */
  .luxury-header__nav-left {
    display: flex;
    gap: 2.5rem;
    align-items: center;
  }
  .luxury-header__nav-link {
    color: var(--text-color);
    text-decoration: none;
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    opacity: 0.8;
    transition: opacity 0.4s cubic-bezier(0.25, 1, 0.5, 1), transform 0.4s cubic-bezier(0.25, 1, 0.5, 1);
    position: relative;
  }
  .luxury-header__nav-link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 1px;
    background-color: var(--text-color);
    transition: width 0.4s cubic-bezier(0.25, 1, 0.5, 1);
  }
  .luxury-header__nav-link:hover {
    opacity: 1;
    transform: translateY(-1px);
  }
  .luxury-header__nav-link:hover::after {
    width: 100%;
  }

  /* Center Logo Container */
  .luxury-header__logo {
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    transition: opacity 0.5s ease;
  }
  .luxury-header__logo:hover {
    opacity: 0.8;
  }

  /* Text Logo Styling */
  .luxury-header__logo-text {
    font-family: var(--heading-font);
    font-size: 32px;
    font-weight: 300;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--text-color);
    margin-right: -0.35em; /* Compensar espaciado de la última letra */
    text-align: center;
    display: inline-block;
  }

  /* Image Logo Styling */
  .luxury-header__logo-img {
    display: block;
    height: auto;
    object-fit: contain;
  }

  /* Right Side Navigation */
  .luxury-header__nav-right {
    display: flex;
    gap: 2.5rem;
    align-items: center;
    justify-content: flex-end;
  }

  /* Mobile Hamburger */
  .luxury-header__hamburger {
    display: none;
    background: none;
    border: none;
    color: var(--text-color);
    cursor: pointer;
    padding: 8px;
    margin-left: -8px;
    opacity: 0.8;
    transition: opacity 0.3s ease;
  }
  .luxury-header__hamburger:hover {
    opacity: 1;
  }
  @media (max-width: 768px) {
    .luxury-header__hamburger {
      display: block;
    }
  }

  /* Mobile Drawer Menu */
  .luxury-header__drawer-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    z-index: 200;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.4s ease, visibility 0.4s ease;
  }
  .luxury-header__drawer-overlay.active {
    opacity: 1;
    visibility: visible;
  }

  .luxury-header__drawer {
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    width: 320px;
    max-width: 85vw;
    background: rgba(13, 13, 13, 0.95);
    backdrop-filter: blur(25px);
    -webkit-backdrop-filter: blur(25px);
    z-index: 210;
    padding: 3rem 2.5rem;
    box-sizing: border-box;
    transform: translateX(-100%);
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    border-right: 1px solid rgba(255, 255, 255, 0.05);
    display: flex;
    flex-direction: column;
    gap: 4rem;
    --text-color: #ffffff !important;
  }
  .luxury-header__drawer.active {
    transform: translateX(0);
  }

  .luxury-header__drawer-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .luxury-header__drawer-logo {
    display: flex;
    align-items: center;
    text-decoration: none;
  }
  .luxury-header__drawer-logo-text {
    font-family: var(--heading-font);
    font-size: 24px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--text-color);
    margin-left: 0.25em;
  }
  .luxury-header__drawer-close {
    background: none;
    border: none;
    color: var(--text-color);
    cursor: pointer;
    padding: 8px;
    opacity: 0.8;
    transition: transform 0.4s ease, opacity 0.3s ease;
  }
  .luxury-header__drawer-close:hover {
    transform: rotate(90deg);
    opacity: 1;
  }

  .luxury-header__drawer-nav {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  .luxury-header__drawer-link {
    color: var(--text-color);
    text-decoration: none;
    font-size: 13px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    opacity: 0.75;
    transition: opacity 0.3s ease, transform 0.3s ease;
    text-align: left;
  }
  .luxury-header__drawer-link:hover {
    opacity: 1;
    transform: translateX(6px);
  }
</style>

<header id="luxury-header" class="luxury-header">
  <div class="luxury-header__container">
    <!-- Hamburger button for mobile -->
    <button onclick="toggleLuxuryDrawer(true)" class="luxury-header__hamburger" aria-label="Abrir Menú">
      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
    </button>

    <!-- Left side shop links (Triple Fallback System) -->
    <nav class="luxury-header__nav-desktop luxury-header__nav-left">
      {%- assign has_nav_blocks = false -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'nav_item' -%}
          {%- assign has_nav_blocks = true -%}
          {%- assign item_url = block.settings.link -%}
          {%- if item_url == blank or item_url == '#' -%}
            {%- assign down_label = block.settings.label | downcase -%}
            {%- if down_label contains 'shop' or down_label contains 'collection' -%}
              {%- assign item_url = '/collections' -%}
            {%- elsif down_label contains 'about' -%}
              {%- assign item_url = '/pages/about' -%}
            {%- elsif down_label contains 'journal' -%}
              {%- assign item_url = '/blogs/journal' -%}
            {%- else -%}
              {%- assign item_url = '#' -%}
            {%- endif -%}
          {%- endif -%}
          <a href="{{ item_url }}" class="luxury-header__nav-link" {{ block.shopify_attributes }}>
            {{ block.settings.label }}
          </a>
        {%- endif -%}
      {%- endfor -%}

      {%- if has_nav_blocks == false -%}
        {%- if section.settings.menu != blank -%}
          {%- for link in linklists[section.settings.menu].links -%}
            <a href="{{ link.url }}" class="luxury-header__nav-link">{{ link.title }}</a>
          {%- endfor -%}
        {%- else -%}
          <a href="/collections" class="luxury-header__nav-link">Shop</a>
          <a href="/collections" class="luxury-header__nav-link">Collections</a>
          <a href="/pages/about" class="luxury-header__nav-link">About</a>
          <a href="/blogs/journal" class="luxury-header__nav-link">Journal</a>
        {%- endif -%}
      {%- endif -%}
    </nav>

    <!-- Center Logo brand title (Text or Image/Isotype Option) -->
    <a href="{{ routes.root_url }}" class="luxury-header__logo">
      {%- if section.settings.logo_type == 'image' and section.settings.logo_image != blank -%}
        <img
          src="{{ section.settings.logo_image | image_url: width: 400 }}"
          alt="{{ section.settings.brand_name | default: shop.name }}"
          style="max-width: {{ section.settings.logo_width }}px; height: auto;"
          class="luxury-header__logo-img"
          width="{{ section.settings.logo_width }}"
          height="auto"
        >
      {%- else -%}
        <span class="luxury-header__logo-text">{{ section.settings.brand_name }}</span>
      {%- endif -%}
    </a>

    <!-- Right side general links -->
    <nav class="luxury-header__nav-desktop luxury-header__nav-right">
      <a href="/collections/all" class="luxury-header__nav-link">Search</a>
      {%- if shop.customer_accounts_enabled -%}
        <a href="/account" class="luxury-header__nav-link">Account</a>
      {%- endif -%}
      <a href="/cart" onclick="openLuxuryCart(event)" class="luxury-header__nav-link">Cart (<span id="cart-icon-bubble">{{ cart.item_count }}</span>)</a>
    </nav>

    <!-- Cart icon for mobile -->
    <a href="/cart" onclick="openLuxuryCart(event)" class="luxury-header__hamburger lg:hidden" style="display: none;" aria-label="Carrito">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
    </a>
  </div>
</header>

<!-- Mobile Navigation Drawer Overlay -->
<div id="luxury-drawer-overlay" onclick="toggleLuxuryDrawer(false)" class="luxury-header__drawer-overlay"></div>

<!-- Mobile Navigation Drawer Panel -->
<aside id="luxury-drawer" class="luxury-header__drawer">
  <div class="luxury-header__drawer-header">
    <a href="{{ routes.root_url }}" class="luxury-header__drawer-logo">
      {%- if section.settings.logo_type == 'image' and section.settings.logo_image != blank -%}
        <img
          src="{{ section.settings.logo_image | image_url: width: 300 }}"
          alt="{{ section.settings.brand_name | default: shop.name }}"
          style="max-width: {{ section.settings.logo_width | times: 0.8 | round }}px; height: auto;"
          class="luxury-header__logo-img"
        >
      {%- else -%}
        <span class="luxury-header__drawer-logo-text">{{ section.settings.brand_name }}</span>
      {%- endif -%}
    </a>
    <button onclick="toggleLuxuryDrawer(false)" class="luxury-header__drawer-close" aria-label="Cerrar Menú">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" x2="6" y1="6" y2="18"/><line x1="6" x2="18" y1="6" y2="18"/></svg>
    </button>
  </div>

  <nav class="luxury-header__drawer-nav">
    {%- if has_nav_blocks -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'nav_item' -%}
          {%- assign item_url = block.settings.link -%}
          {%- if item_url == blank or item_url == '#' -%}
            {%- assign down_label = block.settings.label | downcase -%}
            {%- if down_label contains 'shop' or down_label contains 'collection' -%}
              {%- assign item_url = '/collections' -%}
            {%- elsif down_label contains 'about' -%}
              {%- assign item_url = '/pages/about' -%}
            {%- elsif down_label contains 'journal' -%}
              {%- assign item_url = '/blogs/journal' -%}
            {%- else -%}
              {%- assign item_url = '#' -%}
            {%- endif -%}
          {%- endif -%}
          <a href="{{ item_url }}" class="luxury-header__drawer-link">{{ block.settings.label }}</a>
        {%- endif -%}
      {%- endfor -%}
    {%- else -%}
      {%- if section.settings.menu != blank -%}
        {%- for link in linklists[section.settings.menu].links -%}
          <a href="{{ link.url }}" class="luxury-header__drawer-link">{{ link.title }}</a>
        {%- endfor -%}
      {%- else -%}
        <a href="/collections" class="luxury-header__drawer-link">Shop</a>
        <a href="/collections" class="luxury-header__drawer-link">Collections</a>
        <a href="/pages/about" class="luxury-header__drawer-link">About</a>
        <a href="/blogs/journal" class="luxury-header__drawer-link">Journal</a>
      {%- endif -%}
    {%- endif -%}
    
    <div style="width: 100%; height: 1px; background: rgba(255,255,255,0.08); margin: 1rem 0;"></div>
    
    <a href="/collections/all" class="luxury-header__drawer-link">Search</a>
    {%- if shop.customer_accounts_enabled -%}
      <a href="/account" class="luxury-header__drawer-link">Account</a>
    {%- endif -%}
    <a href="/cart" class="luxury-header__drawer-link">Cart ({{ cart.item_count }})</a>
  </nav>
</aside>

<script>
  function toggleLuxuryDrawer(open) {
    const overlay = document.getElementById('luxury-drawer-overlay');
    const drawer = document.getElementById('luxury-drawer');
    if (open) {
      overlay.classList.add('active');
      drawer.classList.add('active');
      document.body.style.overflow = 'hidden';
    } else {
      overlay.classList.remove('active');
      drawer.classList.remove('active');
      document.body.style.overflow = '';
    }
  }

  // Scroll and Context detection for background translucency
  function initLuxuryHeaderScroll() {
    const header = document.getElementById('luxury-header');
    if (!header) return;

    const isIndex = {% if template == 'index' %}true{% else %}false{% endif %};

    if (!isIndex) {
      header.classList.add('non-index');
      return;
    }

    const checkScroll = () => {
      if (window.scrollY > 50) {
        header.classList.add('scrolled');
      } else {
        header.classList.remove('scrolled');
      }
    };

    window.addEventListener('scroll', checkScroll);
    checkScroll();
  }

  document.addEventListener('DOMContentLoaded', initLuxuryHeaderScroll);
  if (window.Shopify && window.Shopify.designMode) {
    document.addEventListener('shopify:section:load', initLuxuryHeaderScroll);
  }
</script>

{% schema %}
{
  "name": "Header Premium Luxury",
  "settings": [
    {
      "type": "header",
      "content": "Logotipo de la Marca"
    },
    {
      "type": "select",
      "id": "logo_type",
      "label": "Tipo de Logotipo",
      "options": [
        {
          "value": "text",
          "label": "Logotipo de Texto"
        },
        {
          "value": "image",
          "label": "Isotipo o Logotipo en Imagen"
        }
      ],
      "default": "text"
    },
    {
      "type": "text",
      "id": "brand_name",
      "label": "Nombre de la Marca (Texto)",
      "default": "LUMINA"
    },
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Imagen del Logotipo (Isotipo)"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 30,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Ancho del Logotipo (Imagen)",
      "default": 100
    },
    {
      "type": "header",
      "content": "Ajustes de Navegación y Estilos"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menú de Enlaces Alternativo",
      "info": "Opcional. Si añades bloques del tipo 'Pestaña de Navegación', estos tendrán prioridad absoluta."
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Color de Texto General",
      "default": "#ffffff"
    }
  ],
  "blocks": [
    {
      "type": "nav_item",
      "name": "Pestaña de Navegación",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Nombre de la Pestaña",
          "default": "Nueva Pestaña"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Enlace (URL)"
        }
      ]
    }
  ]
}
{% endschema %}
