{%- comment -%}
  Ritual Cosmético / ShopTHEMES - Luxury Collections Grid & Value Props Section (OS 2.0)
  Sección editorial que presenta las colecciones en una cuadrícula asimétrica y un pie de página con propuestas de valor.
{%- endcomment -%}

{%- style -%}
  .luxury-collections-{{ section.id }} {
    --bg-color: {{ section.settings.bg_color | default: '#faf6f0' }};
    --text-color: {{ section.settings.text_color | default: '#1a1c1a' }};
    --accent-color: {{ section.settings.accent_color | default: '#bc9c5d' }};
    --heading-font: 'Cormorant Garamond', serif;
    --sans-font: 'Montserrat', sans-serif;
    --grid-gap: 1.25rem; /* Tight premium grid gap */
    
    background-color: var(--bg-color);
    color: var(--text-color);
    font-family: var(--sans-font);
    box-sizing: border-box;
    width: 100%;
  }

  /* Padding and heights matching snappy premium layout */
  @media (min-width: 992px) {
    .luxury-collections-{{ section.id }} {
      min-height: 100vh;
      padding: 7rem 0 3rem 0;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      box-sizing: border-box;
    }
  }

  @media (max-width: 991px) {
    .luxury-collections-{{ section.id }} {
      padding: 5rem 0 2rem 0;
      --grid-gap: 1rem; /* Tight mobile gap */
    }
  }

  .luxury-collections-{{ section.id }} .luxury-col__container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 4%;
    box-sizing: border-box;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  /* Unified 3-Column Grid Layout */
  .luxury-collections-{{ section.id }} .luxury-col__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--grid-gap, 1.25rem);
    box-sizing: border-box;
    width: 100%;
  }

  @media (max-width: 767px) {
    .luxury-collections-{{ section.id }} .luxury-col__grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }

  /* Editorial Text Column */
  .luxury-collections-{{ section.id }} .luxury-col__text-box {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    box-sizing: border-box;
    height: 100%;
  }

  .luxury-collections-{{ section.id }} .luxury-col__tag {
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.45em;
    color: var(--accent-color);
    margin: 0 0 1.5rem 0;
    display: block;
  }

  .luxury-collections-{{ section.id }} .luxury-col__title {
    font-family: var(--heading-font);
    font-size: clamp(36px, 4vw, 56px);
    font-weight: 300;
    line-height: 1.12;
    margin: 0 0 1.5rem 0;
    letter-spacing: -0.01em;
    color: var(--text-color);
  }

  .luxury-collections-{{ section.id }} .luxury-col__desc {
    font-size: 13.5px;
    font-weight: 300;
    line-height: 1.85;
    opacity: 0.8;
    margin: 0 0 2.5rem 0;
    max-width: 420px;
  }

  .luxury-collections-{{ section.id }} .luxury-col__link {
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: var(--text-color);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    padding-bottom: 8px;
    border-bottom: 1px solid {{ section.settings.text_color | default: '#1a1c1a' | color_modify: 'alpha', 0.25 }};
    transition: border-bottom-color 0.4s ease, gap 0.4s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .luxury-collections-{{ section.id }} .luxury-col__link:hover {
    border-bottom-color: var(--text-color);
    gap: 1.5rem;
  }

  .luxury-collections-{{ section.id }} .luxury-col__link svg {
    width: 14px;
    height: 14px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2px;
    transition: transform 0.4s ease;
  }

  /* Grid span for Necklaces large card on desktop */
  @media (min-width: 768px) {
    .luxury-collections-{{ section.id }} .luxury-col-card--large {
      grid-column: span 2;
    }
  }

  /* Card Component Styles */
  .luxury-collections-{{ section.id }} .luxury-col-card {
    position: relative;
    width: 100%;
    border-radius: 4px;
    overflow: hidden;
    box-sizing: border-box;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.02);
    display: block;
    text-decoration: none;
    color: inherit;
  }

  /* Top right Necklaces card ratio to match vertical height of 1:1 square cards */
  .luxury-collections-{{ section.id }} .luxury-col-card--large {
    padding-bottom: calc(50% - (var(--grid-gap, 1.25rem) / 2)); /* Mathematically aligns heights perfectly */
  }

  @media (max-width: 767px) {
    .luxury-collections-{{ section.id }} .luxury-col-card--large {
      padding-bottom: 60%;
    }
  }

  /* Bottom row square cards ratio */
  .luxury-collections-{{ section.id }} .luxury-col-card--square {
    padding-bottom: 100%; /* Square ratio */
  }

  .luxury-collections-{{ section.id }} .luxury-col-card__img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    z-index: 1;
    transition: transform 1.2s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .luxury-collections-{{ section.id }} .luxury-col-card:hover .luxury-col-card__img {
    transform: scale(1.04);
  }

  .luxury-collections-{{ section.id }} .luxury-col-card__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.45) 0%, rgba(0, 0, 0, 0.15) 50%, rgba(0, 0, 0, 0) 100%);
    z-index: 2;
    transition: opacity 0.4s ease;
  }

  .luxury-collections-{{ section.id }} .luxury-col-card__content {
    position: absolute;
    bottom: 2rem;
    left: 2rem;
    right: 2rem;
    z-index: 3;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.5rem;
    color: #ffffff;
  }

  .luxury-collections-{{ section.id }} .luxury-col-card__title {
    font-family: var(--heading-font);
    font-size: clamp(22px, 2.5vw, 32px);
    font-weight: 300;
    line-height: 1.2;
    margin: 0;
    letter-spacing: 0.02em;
    color: #ffffff;
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.15);
  }

  .luxury-collections-{{ section.id }} .luxury-col-card__link {
    font-size: 8.5px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: rgba(255, 255, 255, 0.9);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    padding-bottom: 4px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.3);
    transition: color 0.4s ease, border-color 0.4s ease, gap 0.4s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .luxury-collections-{{ section.id }} .luxury-col-card:hover .luxury-col-card__link {
    color: #ffffff;
    border-bottom-color: #ffffff;
    gap: 1.2rem;
  }

  .luxury-collections-{{ section.id }} .luxury-col-card__link svg {
    width: 10px;
    height: 10px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2px;
  }

  /* Bottom Value Propositions Bar */
  .luxury-collections-{{ section.id }} .luxury-col__value-bar {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    border-top: 1px solid {{ section.settings.text_color | default: '#1a1c1a' | color_modify: 'alpha', 0.08 }};
    padding: 3rem 0 0 0;
    margin-top: 2rem;
    box-sizing: border-box;
    width: 100%;
  }

  @media (max-width: 991px) {
    .luxury-collections-{{ section.id }} .luxury-col__value-bar {
      grid-template-columns: repeat(2, 1fr);
      gap: 2.5rem;
      padding-top: 2.5rem;
    }
  }

  @media (max-width: 480px) {
    .luxury-collections-{{ section.id }} .luxury-col__value-bar {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }

  .luxury-collections-{{ section.id }} .luxury-value-item {
    display: flex;
    align-items: center;
    gap: 1.2rem;
  }

  .luxury-collections-{{ section.id }} .luxury-value-item__icon {
    display: flex;
    justify-content: center;
    align-items: center;
    color: var(--accent-color);
    flex-shrink: 0;
  }

  .luxury-collections-{{ section.id }} .luxury-value-item__icon svg {
    width: 22px;
    height: 22px;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.5px;
  }

  .luxury-collections-{{ section.id }} .luxury-value-item__text {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .luxury-collections-{{ section.id }} .luxury-value-item__title {
    font-size: 9.5px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--text-color);
    margin: 0;
    line-height: 1.2;
  }

  .luxury-collections-{{ section.id }} .luxury-value-item__desc {
    font-size: 8.5px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--text-color);
    opacity: 0.6;
    margin: 0;
    line-height: 1.2;
  }
{%- endstyle -%}

<div class="luxury-collections-{{ section.id }}">
  <div class="luxury-col__container">
    
    <!-- Unified 3-Column Editorial Grid -->
    <div class="luxury-col__grid">
      
      <!-- Column 1, Row 1: Editorial Text Box -->
      <div class="luxury-col__text-box">
        {%- if section.settings.tagline != blank -%}
          <span class="luxury-col__tag">{{ section.settings.tagline }}</span>
        {%- endif -%}
        {%- if section.settings.title != blank -%}
          <h2 class="luxury-col__title">{{ section.settings.title }}</h2>
        {%- endif -%}
        {%- if section.settings.description != blank -%}
          <p class="luxury-col__desc">{{ section.settings.description }}</p>
        {%- endif -%}
        {%- if section.settings.link_label != blank -%}
          <a href="{{ section.settings.link_url | default: '#' }}" class="luxury-col__link">
            {{ section.settings.link_label }}
            <svg viewBox="0 0 24 24">
              <path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        {%- endif -%}
      </div>

      <!-- Columns 2-3, Row 1: Large Card (Necklaces, block 1) -->
      {%- assign first_block = section.blocks | first -%}
      {%- if first_block -%}
        {%- assign card_url = first_block.settings.url -%}
        {%- if card_url contains 'shopify://' -%}
          {%- assign card_url = card_url | replace: 'shopify://collections/', '/collections/' | replace: 'shopify://products/', '/products/' | replace: 'shopify://pages/', '/pages/' | replace: 'shopify://blogs/', '/blogs/' -%}
        {%- endif -%}
        {%- if card_url == blank or card_url == '#' -%}
          {%- assign down_title = first_block.settings.title | default: 'Necklaces' | downcase -%}
          {%- if down_title contains 'ring' or down_title contains 'anillo' -%}
            {%- assign card_url = '/collections/rings' -%}
          {%- elsif down_title contains 'necklace' or down_title contains 'collar' or down_title contains 'necklece' -%}
            {%- assign card_url = '/collections/necklaces' -%}
          {%- elsif down_title contains 'earring' or down_title contains 'arete' or down_title contains 'pendiente' -%}
            {%- assign card_url = '/collections/earrings' -%}
          {%- elsif down_title contains 'bracelet' or down_title contains 'pulsera' or down_title contains 'brazalete' -%}
            {%- assign card_url = '/collections/bracelets' -%}
          {%- else -%}
            {%- assign card_url = '/collections' -%}
          {%- endif -%}
        {%- endif -%}
        <a href="{{ card_url }}" class="luxury-col-card luxury-col-card--large" {{ first_block.shopify_attributes }}>
          {%- if first_block.settings.image != blank -%}
            <img src="{{ first_block.settings.image | image_url: width: 1200 }}" alt="{{ first_block.settings.title | escape }}" class="luxury-col-card__img" loading="lazy">
          {%- else -%}
            <img src="{{ 'collection-necklaces.png' | asset_url }}" alt="Necklaces Collection" class="luxury-col-card__img" loading="lazy">
          {%- endif -%}
          <div class="luxury-col-card__overlay"></div>
          <div class="luxury-col-card__content">
            <h3 class="luxury-col-card__title">{{ first_block.settings.title | default: 'Necklaces' }}</h3>
            <div class="luxury-col-card__link">
              {{ first_block.settings.link_label | default: 'DISCOVER THE COLLECTION' }}
              <svg viewBox="0 0 24 24">
                <path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </div>
        </a>
      {%- endif -%}

      <!-- Row 2: 3 columns of square cards (Blocks 2, 3, 4) -->
      {%- for block in section.blocks offset: 1 -%}
        {%- assign card_url = block.settings.url -%}
        {%- if card_url contains 'shopify://' -%}
          {%- assign card_url = card_url | replace: 'shopify://collections/', '/collections/' | replace: 'shopify://products/', '/products/' | replace: 'shopify://pages/', '/pages/' | replace: 'shopify://blogs/', '/blogs/' -%}
        {%- endif -%}
        {%- if card_url == blank or card_url == '#' -%}
          {%- assign down_title = block.settings.title | downcase -%}
          {%- if down_title contains 'ring' or down_title contains 'anillo' -%}
            {%- assign card_url = '/collections/rings' -%}
          {%- elsif down_title contains 'necklace' or down_title contains 'collar' or down_title contains 'necklece' -%}
            {%- assign card_url = '/collections/necklaces' -%}
          {%- elsif down_title contains 'earring' or down_title contains 'arete' or down_title contains 'pendiente' -%}
            {%- assign card_url = '/collections/earrings' -%}
          {%- elsif down_title contains 'bracelet' or down_title contains 'pulsera' or down_title contains 'brazalete' -%}
            {%- assign card_url = '/collections/bracelets' -%}
          {%- else -%}
            {%- assign card_url = '/collections' -%}
          {%- endif -%}
        {%- endif -%}
        <a href="{{ card_url }}" class="luxury-col-card luxury-col-card--square" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <img src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ block.settings.title | escape }}" class="luxury-col-card__img" loading="lazy">
          {%- else -%}
            {%- case forloop.index -%}
              {%- when 1 -%}
                <img src="{{ 'collection-rings.png' | asset_url }}" alt="Rings Collection" class="luxury-col-card__img" loading="lazy">
              {%- when 2 -%}
                <img src="{{ 'collection-earrings.png' | asset_url }}" alt="Earrings Collection" class="luxury-col-card__img" loading="lazy">
              {%- else -%}
                <img src="{{ 'collection-bracelets.png' | asset_url }}" alt="Bracelets Collection" class="luxury-col-card__img" loading="lazy">
            {%- endcase -%}
          {%- endif -%}
          <div class="luxury-col-card__overlay"></div>
          <div class="luxury-col-card__content">
            <h3 class="luxury-col-card__title">{{ block.settings.title }}</h3>
            <div class="luxury-col-card__link">
              {{ block.settings.link_label | default: 'DISCOVER THE COLLECTION' }}
              <svg viewBox="0 0 24 24">
                <path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </div>
        </a>
      {%- endfor -%}

    </div>

    <!-- Bottom Horizontal Props Bar -->
    {%- if section.settings.show_props -%}
      <div class="luxury-col__value-bar">
        
        <!-- Prop 1 -->
        <div class="luxury-value-item">
          <div class="luxury-value-item__icon">
            <svg viewBox="0 0 24 24">
              <path d="M12 3l1.8 5.4c.5 1.5 1.7 2.7 3.2 3.2L22 13.5l-5 1.5c-1.5.5-2.7 1.7-3.2 3.2L12 23.7l-1.8-5.4c-.5-1.5-1.7-2.7-3.2-3.2L2 13.5l5-1.5c1.5-.5 2.7-1.7 3.2-3.2L12 3z" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div class="luxury-value-item__text">
            <h4 class="luxury-value-item__title">{{ section.settings.prop_title_1 }}</h4>
            <p class="luxury-value-item__desc">{{ section.settings.prop_desc_1 }}</p>
          </div>
        </div>

        <!-- Prop 2 -->
        <div class="luxury-value-item">
          <div class="luxury-value-item__icon">
            <svg viewBox="0 0 24 24">
              <path d="M12 2C6.48 2 2 6.48 2 12c0 4.42 3.58 8 8 8s8-3.58 8-8c0-5.52-4.48-10-10-10zm0 18c-3.31 0-6-2.69-6-6s2.69-6 6-6 6 2.69 6 6-2.69 6-6 6z" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M12 6c-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4-1.79-4-4-4z" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div class="luxury-value-item__text">
            <h4 class="luxury-value-item__title">{{ section.settings.prop_title_2 }}</h4>
            <p class="luxury-value-item__desc">{{ section.settings.prop_desc_2 }}</p>
          </div>
        </div>

        <!-- Prop 3 -->
        <div class="luxury-value-item">
          <div class="luxury-value-item__icon">
            <svg viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M12 8v8M8 12h8" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div class="luxury-value-item__text">
            <h4 class="luxury-value-item__title">{{ section.settings.prop_title_3 }}</h4>
            <p class="luxury-value-item__desc">{{ section.settings.prop_desc_3 }}</p>
          </div>
        </div>

        <!-- Prop 4 -->
        <div class="luxury-value-item">
          <div class="luxury-value-item__icon">
            <svg viewBox="0 0 24 24">
              <path d="M21 8V5a2 2 0 00-2-2H5a2 2 0 00-2 2v3m18 0v11a2 2 0 00-2 2H5a2 2 0 00-2-2V8m18 0H3m4-5v5m10-5v5" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div class="luxury-value-item__text">
            <h4 class="luxury-value-item__title">{{ section.settings.prop_title_4 }}</h4>
            <p class="luxury-value-item__desc">{{ section.settings.prop_desc_4 }}</p>
          </div>
        </div>

      </div>
    {%- endif -%}

  </div>
</div>

{% schema %}
{
  "name": "Colecciones Editoriales",
  "max_blocks": 4,
  "settings": [
    {
      "type": "header",
      "content": "Estilos y Colores Globales"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Color de Fondo",
      "default": "#faf6f0"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Color del Texto",
      "default": "#1a1c1a"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Color de Acento",
      "default": "#bc9c5d"
    },
    {
      "type": "header",
      "content": "Encabezado Editorial"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Etiqueta (Kicker)",
      "default": "COLLECTIONS"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título Principal",
      "default": "Timeless by design. Made to be lived in."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Descripción",
      "default": "Discover our signature collections, crafted with intention and cherished every day."
    },
    {
      "type": "text",
      "id": "link_label",
      "label": "Texto del Enlace",
      "default": "EXPLORE ALL COLLECTIONS"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "URL del Enlace"
    },
    {
      "type": "header",
      "content": "Propuestas de Valor (Pie de Página)"
    },
    {
      "type": "checkbox",
      "id": "show_props",
      "label": "Mostrar Barra de Propuestas",
      "default": true
    },
    {
      "type": "text",
      "id": "prop_title_1",
      "label": "Título Propuesta 1",
      "default": "HANDCRAFTED"
    },
    {
      "type": "text",
      "id": "prop_desc_1",
      "label": "Detalle Propuesta 1",
      "default": "BY SKILLED ARTISANS"
    },
    {
      "type": "text",
      "id": "prop_title_2",
      "label": "Título Propuesta 2",
      "default": "ETHICAL MATERIALS"
    },
    {
      "type": "text",
      "id": "prop_desc_2",
      "label": "Detalle Propuesta 2",
      "default": "RESPONSIBLY SOURCED"
    },
    {
      "type": "text",
      "id": "prop_title_3",
      "label": "Título Propuesta 3",
      "default": "FINEST QUALITY"
    },
    {
      "type": "text",
      "id": "prop_desc_3",
      "label": "Detalle Propuesta 3",
      "default": "MADE TO LAST"
    },
    {
      "type": "text",
      "id": "prop_title_4",
      "label": "Título Propuesta 4",
      "default": "COMPLIMENTARY SHIPPING"
    },
    {
      "type": "text",
      "id": "prop_desc_4",
      "label": "Detalle Propuesta 4",
      "default": "ON ALL ORDERS"
    }
  ],
  "blocks": [
    {
      "type": "collection_card",
      "name": "Ficha de Colección",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagen de Fondo"
        },
