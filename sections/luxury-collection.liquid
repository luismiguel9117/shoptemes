<script>
  function toggleFilterGroup(header) {
    const group = header.parentNode;
    const content = group.querySelector('.luxury-filter-group__content');
    const icon = group.querySelector('.luxury-filter-group__icon');
    
    if (content.style.display === 'none') {
      content.style.display = 'flex';
      icon.textContent = '−';
    } else {
      content.style.display = 'none';
      icon.textContent = '+';
    }
  }
</script>

