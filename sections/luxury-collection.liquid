{%- comment -%}
  Ritual Cosmético / ShopTHEMES - Luxury Collection Page (OS 2.0 collection template)
  Premium product catalog with a left filter sidebar, minimalist accordion filters, and 3-column product grid.
{%- endcomment -%}

{%- style -%}
  .luxury-collection-page-{{ section.id }} {
    --heading-font: 'Cormorant Garamond', serif;
    --sans-font: 'Montserrat', sans-serif;
    
    background-color: {{ section.settings.bg_color | default: '#fbf9f6' }};
    color: {{ section.settings.text_color | default: '#1a1c1a' }};
    font-family: var(--sans-font);
    padding: 7rem 0 8rem 0;
    box-sizing: border-box;
    width: 100%;
  }

  @media (max-width: 991px) {
    .luxury-collection-page-{{ section.id }} {
      padding: 4rem 0 5rem 0;
    }
  }

  /* Two Column Layout */
  .luxury-col-layout {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 5rem;
    max-width: 1600px;
    margin: 0 auto;
    padding: 0 4rem;
    box-sizing: border-box;
  }

  @media (max-width: 1199px) {
    .luxury-col-layout {
      gap: 3rem;
      padding: 0 2rem;
    }
  }

  @media (max-width: 991px) {
    .luxury-col-layout {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }

  /* LEFT SIDEBAR FILTERS */
  .luxury-col-sidebar {
    display: flex;
    flex-direction: column;
    box-sizing: border-box;
  }

  /* Breadcrumbs */
  .luxury-col-breadcrumbs {
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: #8c8c8c;
    margin-bottom: 1.25rem;
  }

  /* Collection Title */
  .luxury-col-title {
    font-family: var(--heading-font);
    font-size: clamp(36px, 4.5vw, 52px);
    font-weight: 300;
    line-height: 1.1;
    margin: 0 0 1rem 0;
    color: var(--text-color);
    letter-spacing: -0.01em;
  }

  /* Collection Description */
  .luxury-col-desc {
    font-size: 13px;
    line-height: 1.8;
    font-weight: 300;
    color: #666;
    margin: 0 0 2.5rem 0;
    letter-spacing: 0.02em;
    max-width: 240px;
  }

  @media (max-width: 991px) {
    .luxury-col-desc {
      max-width: 100%;
      margin-bottom: 1.5rem;
    }
  }

  /* Filter Accordions */
  .luxury-filter-divider {
    height: 1px;
    background-color: rgba(26, 28, 26, 0.08);
    width: 100%;
    margin: 0;
  }

  .luxury-filter-group {
    padding: 1.5rem 0;
    width: 100%;
    box-sizing: border-box;
  }

  .luxury-filter-group__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    user-select: none;
  }

  .luxury-filter-group__title {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--text-color);
    margin: 0;
  }

  .luxury-filter-group__icon {
    font-size: 14px;
    font-weight: 300;
    color: var(--text-color);
    transition: transform 0.3s ease;
  }

  .luxury-filter-group__content {
    margin-top: 1.5rem;
    display: flex;
    flex-direction: column;
    box-sizing: border-box;
  }

  /* Custom Clean Checkboxes */
  .luxury-filter-checkbox {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    cursor: pointer;
    font-size: 12px;
    font-weight: 300;
    letter-spacing: 0.04em;
    color: var(--text-color);
    margin-bottom: 0.85rem;
    user-select: none;
  }

  .luxury-filter-checkbox:last-child {
    margin-bottom: 0;
  }

  .luxury-filter-checkbox input {
    display: none;
  }

  .luxury-filter-checkbox__box {
    width: 13px;
    height: 13px;
    border: 1px solid rgba(26, 28, 26, 0.2);
    border-radius: 1px;
    background: transparent;
    position: relative;
    box-sizing: border-box;
    transition: border-color 0.3s ease, background-color 0.3s ease;
  }

  .luxury-filter-checkbox input:checked + .luxury-filter-checkbox__box {
    border-color: var(--text-color);
    background-color: var(--text-color);
  }

  .luxury-filter-checkbox input:checked + .luxury-filter-checkbox__box::after {
    content: '';
    position: absolute;
    width: 3px;
    height: 6px;
    border: solid #ffffff;
    border-width: 0 1px 1px 0;
    transform: rotate(45deg);
    top: 1px;
    left: 4px;
    box-sizing: border-box;
  }

  /* Price Range Slider */
  .luxury-price-slider {
    margin: 1.25rem 0 0.5rem 0;
    position: relative;
    padding: 0.5rem 0;
  }

  .luxury-price-slider__track {
    width: 100%;
    height: 1px;
    background: rgba(26, 28, 26, 0.12);
    position: relative;
  }

  .luxury-price-slider__range {
    position: absolute;
    height: 1px;
    background: var(--text-color);
    left: 5%;
    right: 15%;
  }

  .luxury-price-slider__handle {
    position: absolute;
    width: 8px;
    height: 8px;
    background: var(--text-color);
    border-radius: 50%;
    top: -3.5px;
    cursor: pointer;
    box-sizing: border-box;
  }

  .luxury-price-slider__handle--min {
    left: 5%;
    transform: translateX(-50%);
  }

  .luxury-price-slider__handle--max {
    left: 85%;
    transform: translateX(-50%);
  }

  .luxury-price-slider__labels {
    display: flex;
    justify-content: space-between;
    font-size: 11px;
    font-weight: 400;
    color: var(--text-color);
    margin-top: 1.25rem;
    letter-spacing: 0.05em;
  }

  /* RIGHT PRODUCT CATALOG GRID */
  .luxury-col-catalog {
    display: flex;
    flex-direction: column;
    box-sizing: border-box;
  }

  /* Topbar Details */
  .luxury-catalog-topbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid rgba(26, 28, 26, 0.08);
    padding-bottom: 1.25rem;
    margin-bottom: 3rem;
  }

  @media (max-width: 768px) {
    .luxury-catalog-topbar {
      margin-bottom: 2rem;
    }
  }

  .luxury-catalog-topbar__results {
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: #8c8c8c;
  }

  .luxury-catalog-topbar__sort {
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--text-color);
    background: transparent;
    border: none;
    padding: 0;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    outline: none;
  }

  .luxury-catalog-topbar__sort svg {
    width: 8px;
    height: 8px;
    stroke: currentColor;
    fill: none;
    stroke-width: 2px;
  }

  /* Product Grid */
  .luxury-prod-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3.5rem 1.5rem;
    box-sizing: border-box;
  }

  @media (max-width: 1199px) {
    .luxury-prod-grid {
      gap: 2.5rem 1.25rem;
    }
  }

  @media (max-width: 768px) {
    .luxury-prod-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem 1rem;
    }
  }

  /* Product Card */
  .luxury-prod-card {
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    box-sizing: border-box;
  }

  @media (max-width: 768px) {
    .luxury-prod-card {
      gap: 0.75rem;
    }
  }

  .luxury-prod-card__frame {
    width: 100%;
    padding-bottom: 125%; /* Exquisite vertical portrait cropped frame */
    position: relative;
    overflow: hidden;
    background-color: #f5f0eb;
    border-radius: 2px;
  }

  .luxury-prod-card__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 0.6s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .luxury-prod-card:hover .luxury-prod-card__img {
    transform: scale(1.025);
  }

  .luxury-prod-card__info {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .luxury-prod-card__title {
    font-size: 10px;
    font-weight: 500;
    color: var(--text-color);
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    line-height: 1.3;
  }

  .luxury-prod-card__price {
    font-size: 11px;
    font-weight: 300;
    color: #666;
    margin: 0;
    letter-spacing: 0.05em;
  }

  .luxury-prod-card__quick-add {
    width: 100%;
    padding: 0.7rem 0;
    background-color: #1a1c1a;
    color: #ffffff;
    border: none;
    font-family: var(--sans-font);
    font-size: 8.5px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    cursor: pointer;
    transition: background-color 0.3s ease, color 0.3s ease, opacity 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin-top: auto;
    border-radius: 1px;
  }

  .luxury-prod-card__quick-add:hover {
    background-color: #bc9c5d;
  }

  .luxury-prod-card__quick-add:disabled {
    background-color: #d1cbc4;
    color: #8c8c8c;
    cursor: not-allowed;
  }

  /* Pagination */
  .luxury-pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 2.5rem;
    margin-top: 6rem;
    box-sizing: border-box;
    width: 100%;
  }

  @media (max-width: 768px) {
    .luxury-pagination {
      margin-top: 4rem;
      gap: 1.75rem;
    }
  }

  .luxury-pagination__item {
    font-size: 11px;
    font-weight: 400;
    color: var(--text-color);
    opacity: 0.35;
    text-decoration: none;
    letter-spacing: 0.1em;
    padding-bottom: 4px;
    border-bottom: 1px solid transparent;
    transition: opacity 0.3s ease, border-color 0.3s ease;
  }

  .luxury-pagination__item:hover {
    opacity: 1;
  }

  .luxury-pagination__item--active {
    opacity: 1;
    border-bottom-color: var(--text-color);
  }

  .luxury-pagination__item--arrow {
    opacity: 0.6;
    display: inline-flex;
    align-items: center;
  }

  .luxury-pagination__item--arrow svg {
    width: 12px;
    height: 12px;
    stroke: currentColor;
    fill: none;
  }
{%- endstyle -%}

<div class="luxury-collection-page-{{ section.id }}">
  <div class="luxury-col-layout">
    
    <!-- LEFT SIDEBAR: Dynamic & Minimalist Breadcrumbs, Title and Filter accordions -->
    <aside class="luxury-col-sidebar">
      
      <!-- Breadcrumbs -->
      <div class="luxury-col-breadcrumbs">
        Shop / {{ collection.title | default: 'Rings' }}
      </div>

      <!-- Title -->
      <h1 class="luxury-col-title">{{ collection.title | default: 'Rings' }}</h1>

      <!-- Description -->
      <p class="luxury-col-desc">
        {{ collection.description | default: 'Symbols of connection, intention, and beauty. Each ring is a promise—to yourself or to another.' }}
      </p>

      <!-- Accordion: FILTER -->
      <div class="luxury-filter-divider"></div>
      <div class="luxury-filter-group">
        <div class="luxury-filter-group__header" onclick="toggleFilterGroup(this)">
          <h3 class="luxury-filter-group__title">Filter</h3>
          <span class="luxury-filter-group__icon">−</span>
        </div>
        <div class="luxury-filter-group__content">
          
          <!-- Sub-heading: MATERIAL -->
          <div style="font-size: 9px; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; color: #888; margin-bottom: 1rem; margin-top: 0.5rem;">Material</div>
          <label class="luxury-filter-checkbox">
            <input type="checkbox" checked>
            <span class="luxury-filter-checkbox__box"></span>
            18k Yellow Gold
          </label>
          <label class="luxury-filter-checkbox">
            <input type="checkbox">
            <span class="luxury-filter-checkbox__box"></span>
            18k White Gold
          </label>
          <label class="luxury-filter-checkbox">
            <input type="checkbox">
            <span class="luxury-filter-checkbox__box"></span>
            18k Rose Gold
          </label>

          <!-- Sub-heading: STONE -->
          <div style="font-size: 9px; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; color: #888; margin-bottom: 1rem; margin-top: 1.5rem;">Stone</div>
          <label class="luxury-filter-checkbox">
            <input type="checkbox">
            <span class="luxury-filter-checkbox__box"></span>
            Diamond
          </label>
          <label class="luxury-filter-checkbox">
            <input type="checkbox">
            <span class="luxury-filter-checkbox__box"></span>
            Pearl
          </label>
          <label class="luxury-filter-checkbox">
            <input type="checkbox">
            <span class="luxury-filter-checkbox__box"></span>
            Emerald
          </label>
          <label class="luxury-filter-checkbox">
            <input type="checkbox">
            <span class="luxury-filter-checkbox__box"></span>
            Sapphire
          </label>
          <label class="luxury-filter-checkbox">
            <input type="checkbox">
            <span class="luxury-filter-checkbox__box"></span>
            No Stone
          </label>

          <!-- Sub-heading: PRICE -->
          <div style="font-size: 9px; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; color: #888; margin-bottom: 0.5rem; margin-top: 1.5rem;">Price</div>
          <div class="luxury-price-slider">
            <div class="luxury-price-slider__track">
              <div class="luxury-price-slider__range"></div>
              <div class="luxury-price-slider__handle luxury-price-slider__handle--min"></div>
              <div class="luxury-price-slider__handle luxury-price-slider__handle--max"></div>
            </div>
            <div class="luxury-price-slider__labels">
              <span>€220</span>
              <span>€8,500</span>
            </div>
          </div>

        </div>
      </div>

      <!-- Accordion: SORT BY -->
      <div class="luxury-filter-divider"></div>
      <div class="luxury-filter-group">
        <div class="luxury-filter-group__header" onclick="toggleFilterGroup(this)">
          <h3 class="luxury-filter-group__title">Sort By</h3>
          <span class="luxury-filter-group__icon">+</span>
        </div>
        <div class="luxury-filter-group__content" style="display: none;">
          <label class="luxury-filter-checkbox">
            <input type="radio" name="sort_by" checked style="display: none;">
            <span class="luxury-filter-checkbox__box" style="border-radius: 50%;"></span>
            Featured
          </label>
          <label class="luxury-filter-checkbox">
            <input type="radio" name="sort_by" style="display: none;">
            <span class="luxury-filter-checkbox__box" style="border-radius: 50%;"></span>
            Price: Low to High
          </label>
          <label class="luxury-filter-checkbox">
            <input type="radio" name="sort_by" style="display: none;">
            <span class="luxury-filter-checkbox__box" style="border-radius: 50%;"></span>
            Price: High to Low
          </label>
        </div>
      </div>
      <div class="luxury-filter-divider"></div>

    </aside>

    <!-- RIGHT SIDE: Products display matching the exquisite grid and card properties -->
    <main class="luxury-col-catalog">
      
      <!-- Topbar filters status details -->
      <div class="luxury-catalog-topbar">
        {%- if collection.products.size > 0 -%}
          <div class="luxury-catalog-topbar__results">
            {{ collection.products_count }} RESULTS
          </div>
        {%- else -%}
          <div class="luxury-catalog-topbar__results">
            24 RESULTS
          </div>
        {%- endif -%}
        
        <button class="luxury-catalog-topbar__sort">
          Featured
          <svg viewBox="0 0 24 24">
            <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>

      <!-- Product Listing dynamic / fallback grid -->
      <div class="luxury-prod-grid">
        {%- assign real_fallback_variant = all_products.first.selected_or_first_available_variant.id -%}
        {%- if real_fallback_variant == blank -%}
          {%- for p in collections.all.products -%}{%- if p.selected_or_first_available_variant.id != blank -%}{%- assign real_fallback_variant = p.selected_or_first_available_variant.id -%}{%- break -%}{%- endif -%}{%- endfor -%}
        {%- endif -%}

        {%- if collection.products.size > 0 -%}
          {%- comment -%} Loop through actual Shopify products when populated {%- endcomment -%}
          {%- paginate collection.products by 12 -%}
            {%- for product in collection.products -%}
              <div class="luxury-prod-card-container" style="display: flex; flex-direction: column; gap: 0.75rem; position: relative;">
                <a href="{{ product.url }}" class="luxury-prod-card" style="text-decoration: none;">
                  <div class="luxury-prod-card__frame">
                    {%- if product.featured_image != blank -%}
                      <img src="{{ product.featured_image | image_url: width: 800 }}" alt="{{ product.title | escape }}" class="luxury-prod-card__img" loading="lazy">
                    {%- else -%}
                      {{ 'image' | placeholder_svg_tag: 'luxury-prod-card__img' }}
                    {%- endif -%}
                  </div>
                  <div class="luxury-prod-card__info" style="margin-top: 0.5rem;">
                    <h3 class="luxury-prod-card__title">{{ product.title }}</h3>
                    <p class="luxury-prod-card__price">{{ product.price | money_without_trailing_zeros }}</p>
                  </div>
                </a>
                <button onclick="addCatalogProductToCart(event, {{ product.selected_or_first_available_variant.id }})" class="luxury-prod-card__quick-add">
                  <span>Añadir al Carrito</span>
                </button>
              </div>
            {%- endfor -%}
          {%- endpaginate -%}
        {%- else -%}
          
          <!-- Mockup Jewelry Items - Solitaire Ring -->
          <div class="luxury-prod-card-container" style="display: flex; flex-direction: column; gap: 0.75rem; position: relative;">
            <a href="#" class="luxury-prod-card" style="text-decoration: none;">
              <div class="luxury-prod-card__frame">
                <img src="https://images.unsplash.com/photo-1605100804763-247f67b3557e?auto=format&fit=crop&w=600&q=80" alt="Solitaire Ring" class="luxury-prod-card__img" loading="lazy">
              </div>
              <div class="luxury-prod-card__info" style="margin-top: 0.5rem;">
                <h3 class="luxury-prod-card__title">Solitaire Ring</h3>
                <p class="luxury-prod-card__price">€1,850</p>
              </div>
            </a>
            <button onclick="addCatalogProductToCart(event, {{ real_fallback_variant | default: 0 }})" class="luxury-prod-card__quick-add" {% if real_fallback_variant == blank %}disabled{% endif %}>
              <span>Añadir al Carrito</span>
            </button>
          </div>

          <!-- Mockup Jewelry Items - Texture Band -->
          <div class="luxury-prod-card-container" style="display: flex; flex-direction: column; gap: 0.75rem; position: relative;">
            <a href="#" class="luxury-prod-card" style="text-decoration: none;">
              <div class="luxury-prod-card__frame">
                <img src="https://images.unsplash.com/photo-1603561591411-07134e71a2a9?auto=format&fit=crop&w=600&q=80" alt="Texture Band" class="luxury-prod-card__img" loading="lazy">
              </div>
              <div class="luxury-prod-card__info" style="margin-top: 0.5rem;">
                <h3 class="luxury-prod-card__title">Texture Band</h3>
                <p class="luxury-prod-card__price">€950</p>
              </div>
            </a>
            <button onclick="addCatalogProductToCart(event, {{ real_fallback_variant | default: 0 }})" class="luxury-prod-card__quick-add" {% if real_fallback_variant == blank %}disabled{% endif %}>
              <span>Añadir al Carrito</span>
            </button>
          </div>

          <!-- Mockup Jewelry Items - Trio Diamond Ring -->
          <div class="luxury-prod-card-container" style="display: flex; flex-direction: column; gap: 0.75rem; position: relative;">
            <a href="#" class="luxury-prod-card" style="text-decoration: none;">
              <div class="luxury-prod-card__frame">
                <img src="https://images.unsplash.com/photo-1598560917505-59a3ad559071?auto=format&fit=crop&w=600&q=80" alt="Trio Diamond Ring" class="luxury-prod-card__img" loading="lazy">
              </div>
              <div class="luxury-prod-card__info" style="margin-top: 0.5rem;">
                <h3 class="luxury-prod-card__title">Trio Diamond Ring</h3>
                <p class="luxury-prod-card__price">€2,450</p>
              </div>
            </a>
            <button onclick="addCatalogProductToCart(event, {{ real_fallback_variant | default: 0 }})" class="luxury-prod-card__quick-add" {% if real_fallback_variant == blank %}disabled{% endif %}>
              <span>Añadir al Carrito</span>
            </button>
          </div>

          <!-- Mockup Jewelry Items - Twist Ring -->
          <div class="luxury-prod-card-container" style="display: flex; flex-direction: column; gap: 0.75rem; position: relative;">
            <a href="#" class="luxury-prod-card" style="text-decoration: none;">
              <div class="luxury-prod-card__frame">
                <img src="https://images.unsplash.com/photo-1605100804763-247f67b3557e?auto=format&fit=crop&w=600&q=80" alt="Twist Ring" class="luxury-prod-card__img" loading="lazy">
              </div>
              <div class="luxury-prod-card__info" style="margin-top: 0.5rem;">
                <h3 class="luxury-prod-card__title">Twist Ring</h3>
                <p class="luxury-prod-card__price">€780</p>
              </div>
            </a>
            <button onclick="addCatalogProductToCart(event, {{ real_fallback_variant | default: 0 }})" class="luxury-prod-card__quick-add" {% if real_fallback_variant == blank %}disabled{% endif %}>
              <span>Añadir al Carrito</span>
            </button>
          </div>

          <!-- Mockup Jewelry Items - Emerald Cut Ring -->
          <div class="luxury-prod-card-container" style="display: flex; flex-direction: column; gap: 0.75rem; position: relative;">
            <a href="#" class="luxury-prod-card" style="text-decoration: none;">
              <div class="luxury-prod-card__frame">
                <img src="https://images.unsplash.com/photo-1605100804763-247f67b3557e?auto=format&fit=crop&w=600&q=80" alt="Emerald Cut Ring" class="luxury-prod-card__img" loading="lazy">
              </div>
              <div class="luxury-prod-card__info" style="margin-top: 0.5rem;">
                <h3 class="luxury-prod-card__title">Emerald Cut Ring</h3>
                <p class="luxury-prod-card__price">€2,150</p>
