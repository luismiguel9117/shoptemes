<section id="favorites" class="py-16 md:py-20 px-6 md:px-20 bg-surface-container-low overflow-hidden">
  <div class="max-w-7xl mx-auto">
    <div class="flex justify-between items-end mb-8">
      <div class="space-y-2">
        <p class="text-[10px] font-black tracking-[0.4em] uppercase text-secondary">Más Vendidos</p>
        <h2 class="font-serif text-3xl md:text-5xl text-primary">{{ section.settings.title | default: 'Favoritos de la Temporada' }}</h2>
      </div>
      <div class="flex gap-2">
        <button id="prev-product-btn" class="w-12 h-12 rounded-full border border-outline-variant flex items-center justify-center hover:bg-white hover:border-primary transition-all cursor-pointer group">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-primary group-hover:-translate-x-1 transition-transform"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
        </button>
        <button id="next-product-btn" class="w-12 h-12 rounded-full border border-outline-variant flex items-center justify-center hover:bg-white hover:border-primary transition-all cursor-pointer group">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-primary group-hover:translate-x-1 transition-transform"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </button>
      </div>
    </div>

    <div class="relative">
      <div class="flex gap-6 py-10 px-4 overflow-x-auto snap-x snap-mandatory hide-scrollbar" id="product-slider">
        {% assign collection = collections[section.settings.collection] %}
        
        {% if collection.products.size == 0 %}
          <div class="min-w-full flex flex-col items-center justify-center py-20 text-center space-y-4">
            <p class="text-on-surface-variant font-light">Asigna una colección en el editor del tema.</p>
          </div>
        {% else %}
          {% for product in collection.products limit: section.settings.products_to_show %}
            <div class="snap-start glass-panel p-0 rounded-[28px] hover:shadow-2xl transition-all duration-500 border border-outline-variant/30 overflow-hidden w-[80vw] sm:w-[calc(50vw-100px)] lg:w-[calc(33.33vw-100px)] shrink-0">
              <div class="flex flex-col h-full">
                <a href="{{ product.url }}" class="aspect-square rounded-[20px] overflow-hidden m-2 bg-[#f0ebe3] shrink-0 block">
                  <img src="{{ product.featured_image | img_url: '600x600', crop: 'center' }}" alt="{{ product.title | escape }}" class="w-full h-full object-cover transition-transform duration-500 hover:scale-105" loading="lazy" />
                </a>
                <div class="p-4 pt-2 flex flex-col flex-1">
                  <div class="mb-4">
                    <div class="flex justify-between items-start mb-1 gap-2">
                      <h3 class="font-serif text-xl text-[#1a1c1a] m-0 font-normal line-clamp-2 leading-tight flex-1">
                        <a href="{{ product.url }}">{{ product.title }}</a>
                      </h3>
                      <span class="text-[15px] font-black text-[#d4af37] whitespace-nowrap pt-0.5">
                        {{ product.price | money }}
                      </span>
                    </div>
                    <p class="text-[11px] text-[#999] m-0 uppercase tracking-wider">
                      {{ product.type }}
                    </p>
                  </div>
                  
                  <div class="grid grid-cols-2 gap-2 mt-auto">
                    <a href="{{ product.url }}" style="padding: 0.75rem; border: 1.5px solid #1a1c1a; color: #1a1c1a; background: transparent; border-radius: 9999px; font-size: 9px; font-weight: 900; letter-spacing: 0.2em; text-transform: uppercase; cursor: pointer; text-align: center;">Info</a>
                    
                    {% form 'product', product %}
                      <input type="hidden" name="id" value="{{ product.variants.first.id }}">
                      <button type="submit" style="padding: 0.75rem; background: #1a1c1a; color: white; border: none; border-radius: 9999px; font-size: 9px; font-weight: 900; letter-spacing: 0.2em; text-transform: uppercase; cursor: pointer; width: 100%;">
                        Añadir
                      </button>
                    {% endform %}
                  </div>
                </div>
              </div>
            </div>
          {% endfor %}
        {% endif %}
      </div>
    </div>
  </div>
</section>

<style>
  /* Hide scrollbar for slider */
  .hide-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .hide-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
    scroll-behavior: smooth;
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const slider = document.getElementById('product-slider');
    const nextBtn = document.getElementById('next-product-btn');
    const prevBtn = document.getElementById('prev-product-btn');
    
    if(slider && nextBtn && prevBtn) {
      nextBtn.addEventListener('click', () => {
        const itemWidth = slider.firstElementChild ? slider.firstElementChild.clientWidth : 300;
        slider.scrollBy({ left: itemWidth + 24, behavior: 'smooth' });
      });
      prevBtn.addEventListener('click', () => {
        const itemWidth = slider.firstElementChild ? slider.firstElementChild.clientWidth : 300;
        slider.scrollBy({ left: -(itemWidth + 24), behavior: 'smooth' });
      });
    }
  });
</script>

{% schema %}
{
  "name": "Product Grid",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Título de la sección",
      "default": "Favoritos de la Temporada"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Colección a mostrar"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 4,
      "max": 12,
      "step": 4,
      "default": 8,
      "label": "Cantidad de productos"
    }
  ],
  "presets": [
    {
      "name": "Grid de Productos"
    }
  ]
}
{% endschema %}
