{%- comment -%}
  Ritual Cosmético / ShopTHEMES - Luxury Hero Section (OS 2.0 Banner Pure Content)
  Este componente se enfoca 100% en la presentación visual del Hero (títulos, espaciadores, descripciones, botones).
{%- endcomment -%}

<style>
  .luxury-hero-{{ section.id }} {
    --heading-font: 'Cormorant Garamond', serif;
    --sans-font: 'Montserrat', sans-serif;
    
    --text-color: {{ section.settings.text_color }};
    --overlay-color: {{ section.settings.overlay_color }};
    --overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    
    --btn-fill-bg: {{ section.settings.btn_fill_bg }};
    --btn-fill-text: {{ section.settings.btn_fill_text }};
    
    position: relative;
    width: 100%;
    height: 100vh;
    min-height: 600px;
    overflow: hidden;
    background-color: #0d0d0d;
    color: var(--text-color);
    font-family: var(--sans-font);
  }

  /* Background Image & Overlay */
  .luxury-hero-{{ section.id }} .luxury-hero__bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }
  .luxury-hero-{{ section.id }} .luxury-hero__bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transform: scale(1.03);
    transition: transform 3s cubic-bezier(0.25, 1, 0.5, 1);
  }
  .luxury-hero-{{ section.id }}:hover .luxury-hero__bg-img {
    transform: scale(1);
  }
  .luxury-hero-{{ section.id }} .luxury-hero__overlay {
    position: absolute;
    inset: 0;
    background: var(--overlay-color);
    opacity: var(--overlay-opacity);
    z-index: 2;
    transition: opacity 0.5s ease;
  }

  /* Main Hero Content Container */
  .luxury-hero-{{ section.id }} .luxury-hero__container {
    position: relative;
    z-index: 10;
    height: 100%;
    max-width: 1600px;
    margin: 0 auto;
    padding: 0 4rem;
    display: flex;
    align-items: center;
    box-sizing: border-box;
  }
  @media (max-width: 768px) {
    .luxury-hero-{{ section.id }} .luxury-hero__container {
      padding: 0 2rem;
    }
  }
  .luxury-hero-{{ section.id }} .luxury-hero__content {
    max-width: 680px;
    text-align: left;
    margin-top: 4rem;
  }

  /* Subtitle Block */
  .luxury-hero-{{ section.id }} .luxury-hero__subtitle {
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.45em;
    display: block;
    margin: 0;
    opacity: 0;
    animation: fadeInUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  /* Title Block */
  .luxury-hero-{{ section.id }} .luxury-hero__title {
    font-family: var(--heading-font);
    font-size: clamp(48px, 6vw, 84px);
    font-weight: 300;
    line-height: 0.95;
    margin: 0;
    text-transform: none;
    letter-spacing: -0.02em;
    color: var(--text-color);
    opacity: 0;
    animation: fadeInUp 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  .luxury-hero-{{ section.id }} .luxury-hero__title span.italic {
    font-family: var(--heading-font);
    font-style: italic;
    font-weight: 300;
    display: block;
    opacity: 0.9;
  }

  /* Description Block */
  .luxury-hero-{{ section.id }} .luxury-hero__desc {
    font-size: clamp(13px, 1.5vw, 15px);
    line-height: 1.8;
    margin: 0;
    font-weight: 300;
    opacity: 0;
    animation: fadeInUp 1.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  /* CTAs: Underlined Link vs Dual Pills */
  .luxury-hero-{{ section.id }} .luxury-hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    align-items: center;
    opacity: 0;
    animation: fadeInUp 1.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  
  /* Underlined Link Style */
  .luxury-hero-{{ section.id }} .luxury-hero__cta-underline {
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: var(--text-color);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    padding-bottom: 8px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.4);
    transition: border-bottom-color 0.4s ease, gap 0.4s cubic-bezier(0.25, 1, 0.5, 1);
  }
  .luxury-hero-{{ section.id }} .luxury-hero__cta-underline:hover {
    border-bottom-color: var(--text-color);
    gap: 1.5rem;
  }
  .luxury-hero-{{ section.id }} .luxury-hero__cta-underline svg {
    width: 18px;
    height: 12px;
    fill: currentColor;
    transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1);
  }

  /* Pills Style */
  .luxury-hero-{{ section.id }} .luxury-hero__btn-fill {
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    background-color: var(--btn-fill-bg);
    color: var(--btn-fill-text);
    padding: 1.1rem 2.5rem;
    border-radius: 9999px;
    text-decoration: none;
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
    transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1), background-color 0.4s ease, box-shadow 0.4s ease;
  }
  .luxury-hero-{{ section.id }} .luxury-hero__btn-fill:hover {
    transform: translateY(-2px);
    background-color: rgba(255, 255, 255, 0.9);
    box-shadow: 0 8px 30px rgba(255, 255, 255, 0.15);
  }
  
  .luxury-hero-{{ section.id }} .luxury-hero__btn-outline {
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    background-color: rgba(255,255,255,0.03);
    color: var(--text-color);
    padding: 1.1rem 2.5rem;
    border-radius: 9999px;
    text-decoration: none;
    border: 1px solid rgba(255, 255, 255, 0.3);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1), border-color 0.4s ease, background-color 0.4s ease;
  }
  .luxury-hero-{{ section.id }} .luxury-hero__btn-outline:hover {
    transform: translateY(-2px);
    border-color: var(--text-color);
    background-color: rgba(255,255,255,0.08);
  }

  /* Spacers */
  .luxury-hero-{{ section.id }} .luxury-hero__spacer {
    width: 100%;
    clear: both;
  }

  /* Bottom Details Grid */
  .luxury-hero-{{ section.id }} .luxury-hero__bottom {
    position: absolute;
    bottom: 2.5rem;
    left: 4rem;
    right: 4rem;
    z-index: 20;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    box-sizing: border-box;
  }
  @media (max-width: 768px) {
    .luxury-hero-{{ section.id }} .luxury-hero__bottom {
      left: 2rem;
      right: 2rem;
      bottom: 2rem;
    }
    .luxury-hero-{{ section.id }} .luxury-hero__bottom-right {
      display: none !important;
    }
  }
  .luxury-hero-{{ section.id }} .luxury-hero__bottom-block {
    opacity: 0.65;
    transition: opacity 0.5s ease;
  }
  .luxury-hero-{{ section.id }} .luxury-hero__bottom-block:hover {
    opacity: 0.95;
  }
  .luxury-hero-{{ section.id }} .luxury-hero__bottom-label {
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    margin: 0 0 6px 0;
  }
  .luxury-hero-{{ section.id }} .luxury-hero__bottom-val {
    font-size: 13px;
    margin: 0;
    font-weight: 300;
  }

  /* Slides Carousel Indicator (Bottom-Left custom visual) */
  .luxury-hero-{{ section.id }} .luxury-hero__indicator {
    position: absolute;
    bottom: 12rem;
    left: 4rem;
    z-index: 20;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
  }
  @media (max-width: 768px) {
    .luxury-hero-{{ section.id }} .luxury-hero__indicator {
      display: none !important;
    }
  }
  .luxury-hero-{{ section.id }} .luxury-hero__indicator-line {
    width: 1px;
    height: 60px;
    background-color: var(--text-color);
    opacity: 0.35;
    position: relative;
    overflow: hidden;
  }
  .luxury-hero-{{ section.id }} .luxury-hero__indicator-line::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 40%;
    background-color: var(--text-color);
  }
  .luxury-hero-{{ section.id }} .luxury-hero__indicator-num {
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.1em;
    opacity: 0.65;
    line-height: 1.5;
  }

  /* FadeInUp entry animations */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<div class="luxury-hero-{{ section.id }}">
  <!-- Background Image with responsive sizing -->
  <div class="luxury-hero__bg">
    {%- if section.settings.image != blank -%}
      <picture>
        {%- if section.settings.image_mobile != blank -%}
          <source media="(max-width: 768px)" srcset="{{ section.settings.image_mobile | image_url: width: 768 }}">
        {%- endif -%}
        <img
          srcset="{{ section.settings.image | image_url: width: 600 }} 600w,
                  {{ section.settings.image | image_url: width: 1200 }} 1200w,
                  {{ section.settings.image | image_url: width: 1600 }} 1600w,
                  {{ section.settings.image | image_url: width: 2000 }} 2000w"
          src="{{ section.settings.image | image_url: width: 1600 }}"
          alt="{{ section.settings.image.alt | escape }}"
          loading="eager"
          width="100%"
          height="100%"
          class="luxury-hero__bg-img"
        >
      </picture>
    {%- else -%}
      <img
        src="{{ 'luxury-hero-bg.jpg' | asset_url }}"
        alt="Luxury Jewelry Default Background"
        loading="eager"
        width="100%"
        height="100%"
        class="luxury-hero__bg-img"
      >
    {%- endif -%}
    <div class="luxury-hero__overlay"></div>
  </div>

  <!-- Main visual indicators (LUMINA slide style) -->
  {%- if section.settings.show_slide_indicator -%}
    <div class="luxury-hero__indicator">
      <div class="luxury-hero__indicator-line"></div>
      <div class="luxury-hero__indicator-num">
        {{ section.settings.slide_current }}<br>
        {{ section.settings.slide_total }}
      </div>
    </div>
  {%- endif -%}

  <!-- Main Content container iterating blocks -->
  <div class="luxury-hero__container">
    <div class="luxury-hero__content">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          
          {%- when 'subtitle' -%}
            {%- if block.settings.text != blank -%}
              <span class="luxury-hero__subtitle" style="{% if block.settings.color != blank %}color: {{ block.settings.color }};{% endif %}" {{ block.shopify_attributes }}>
                {{ block.settings.text }}
              </span>
            {%- endif -%}

          {%- when 'title' -%}
            <h1 class="luxury-hero__title" style="{% if block.settings.color != blank %}color: {{ block.settings.color }};{% endif %}" {{ block.shopify_attributes }}>
              {{ block.settings.title_line_1 }}
              {%- if block.settings.title_line_2 != blank -%}
                <span class="{% if block.settings.title_line_2_italic %}italic{% endif %}">
                  {{ block.settings.title_line_2 }}
                </span>
              {%- endif -%}
            </h1>

          {%- when 'description' -%}
            {%- if block.settings.text != blank -%}
              <p class="luxury-hero__desc" style="max-width: {{ block.settings.max_width }}px; {% if block.settings.color != blank %}color: {{ block.settings.color }};{% endif %}" {{ block.shopify_attributes }}>
                {{ block.settings.text }}
              </p>
            {%- endif -%}

          {%- when 'buttons' -%}
            <div class="luxury-hero__ctas" {{ block.shopify_attributes }}>
              {%- if block.settings.button_style == 'underline' -%}
                {%- if block.settings.btn_1_label != blank -%}
                  <a href="{{ block.settings.btn_1_link | default: '#' }}" class="luxury-hero__cta-underline">
                    {{ block.settings.btn_1_label }}
                    <svg viewBox="0 0 24 24">
                      <path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </a>
                {%- endif -%}
              {%- else -%}
                {%- if block.settings.btn_1_label != blank -%}
                  <a href="{{ block.settings.btn_1_link | default: '#' }}" class="luxury-hero__btn-fill">
                    {{ block.settings.btn_1_label }}
                  </a>
                {%- endif -%}
                {%- if block.settings.btn_2_label != blank -%}
                  <a href="{{ block.settings.btn_2_link | default: '#' }}" class="luxury-hero__btn-outline">
                    {{ block.settings.btn_2_label }}
                  </a>
                {%- endif -%}
              {%- endif -%}
            </div>

          {%- when 'spacer' -%}
            <div class="luxury-hero__spacer" style="height: {{ block.settings.height }}px;" {{ block.shopify_attributes }}></div>

        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>

  <!-- Bottom Craftsmanship details -->
  <div class="luxury-hero__bottom">
    <div class="luxury-hero__bottom-block luxury-hero__bottom-left">
      <p class="luxury-hero__bottom-label">{{ section.settings.bottom_left_label }}</p>
      <p class="luxury-hero__bottom-val">{{ section.settings.bottom_left_text }}</p>
    </div>

    <div class="luxury-hero__bottom-block luxury-hero__bottom-right">
      <p class="luxury-hero__bottom-label">{{ section.settings.bottom_right_label }}</p>
      <p class="luxury-hero__bottom-val">{{ section.settings.bottom_right_text }}</p>
    </div>
  </div>
</div>

